{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MD Reader",
  "version": "0.1.1",
  "identifier": "com.mdreader.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MD Reader",
        "width": 1100,
        "height": 760,
        "minWidth": 600,
        "minHeight": 400,
        "visible": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx"],
        "name": "Markdown Document",
        "description": "Markdown Document",
        "role": "Viewer"
      }
    ]
  }
}
